# ============================================================================
#  VHS-Upscale-Orchestrator — Konfiguration
#  Kopiere diese Datei nach `.env` und trage deine Werte ein.
#  .env ist in .gitignore — Secrets landen NIE im Repo.
# ============================================================================

# --- Vast.ai -----------------------------------------------------------------
# Dein Vast API Key (console.vast.ai -> Account -> API Key).
# WIRD NUR ALS ENV-VAR / DOCKER-SECRET GELESEN, niemals im Code hardcodieren.
VAST_API_KEY=

# Mindest-Host-RAM je GPU (GB) beim Buchen. SeedVR2 kompiliert (torch.compile,
# ~45-50 GB/Worker) UND allokiert beim VAE-Decoding den kompletten Output-Tensor
# am Stück (langer Clip -> zweistellige GB) -> auf RAM-knappen Nodes OOM-'Killed'.
# Der Offer-Filter (plan/TUI) lässt nur Nodes mit genug RAM/GPU durch. In der TUI
# per [r] im "Node dazu"-Overlay live änderbar. Zu hoch -> evtl. keine Offers.
MIN_RAM_PER_GPU_GB=96

# Docker-Image für die Vast-Node. Die RTX 5090 (Blackwell, sm_120) braucht ein
# torch mit cu128/sm_120-Kernel — sonst scheitert schon torch.randn(device=cuda)
# und bootstrap.sh müsste torch mehrere GB groß neu installieren (langsam!).
# vastai/pytorch:@vastai-automatic-tag wählt den zur GPU passenden CUDA-Build
# (für die 5090 = cu128) -> torch funktioniert sofort, der cu128-Reinstall in
# bootstrap.sh entfällt. Die Probe+Reinstall-Logik bleibt als Sicherheitsnetz.
# (Fallback bei Buchungsproblemen: pytorch/pytorch:2.8.0-cuda12.8-cudnn9-devel)
VAST_IMAGE=vastai/pytorch:@vastai-automatic-tag

# Disk in GB, die bei der Buchung angefragt wird (>= 300 laut Anforderung).
VAST_DISK_GB=320

# --- SSH (ausgehend Home -> Vast) --------------------------------------------
# Privater SSH-Key, mit dem der Orchestrator die Node erreicht.
# Der ZUGEHÖRIGE ÖFFENTLICHE Key muss in deinem Vast-Account hinterlegt sein
# (console.vast.ai -> Account -> SSH Keys), damit die Instanzen ihn akzeptieren.
SSH_KEY_PATH=/secrets/id_ed25519

# Optionaler zusätzlicher Public-Key-String, den bootstrap.sh in die
# authorized_keys der Node schreibt (Fallback, meist nicht nötig).
SSH_PUBKEY=

# --- Datenpfade (im Container) -----------------------------------------------
# Diese Pfade sind CONTAINER-INTERN. Das Mapping auf die WD Red passiert in
# docker-compose.yml (siehe dortige Kommentare / Sicherheitshinweise).
RAW_DIR=/data/raw
DONE_DIR=/data/done
STATE_DIR=/state

# --- Node-Bootstrap ----------------------------------------------------------
# Roh-URL zu process.sh in DEINEM public Repo (curl-Bootstrapping).
# Nach dem ersten `git push` ggf. Branch/Handle anpassen.
REPO_RAW_URL=https://raw.githubusercontent.com/nitroglyzerin/videoupscale/main

# --- Scheduler ---------------------------------------------------------------
# Wie oft der run-Loop pollt (Sekunden).
POLL_INTERVAL=30
# Datei gilt als "vollständig hochgeladen", wenn ihre Größe über so viele
# aufeinanderfolgende Checks stabil bleibt.
STABLE_CHECKS=2
# Auto-Destroy: Node zerstören, sobald ihre Queue leer UND alle Ergebnisse
# eingesammelt sind. 1 = an (Kostenschutz, empfohlen), 0 = aus.
AUTO_DESTROY=1
# Flow-Control für den Upload: pro Node werden nur so viele Clips gleichzeitig
# "in Arbeit" gehalten wie die Node GPUs hat, multipliziert mit diesem Faktor.
# Nachschub kommt erst, wenn die Node Rückstand abbaut -> minimaler Node-
# Speicher, Rohvideos bleiben zuhause, Upload+Verarbeitung überlappen.
#   1 = exakt GPU-Menge (straffster Puffer), 2 = etwas Reserve (empfohlen).
INFLIGHT_PER_GPU=2
# Sekunden zwischen den (read-only) SSH-Probes der Nodes (Live-Status/Snapshot).
PROBE_INTERVAL=5
# Parallele Slots für lange Transfers (Modelle pushen / Clips / Pull).
HEAVY_WORKERS=4

# --- Worker-Supervisor (Auto-Neustart wedged Worker) -------------------------
# Ein Worker gilt als "wedged", wenn process.sh laut pgrep läuft, aber KEINE GPU
# einen Clip verarbeitet, obwohl echte Restarbeit ansteht. Der Supervisor startet
# ihn dann automatisch neu (killt den toten Baum + Inferenz-Kinder, startet frisch).
# GRACE = Sekunden, die der Zustand am Stück anhalten muss, bevor neu gestartet
# wird. torch.compile läuft erst NACH dem Claim eines Clips (unter busy=1) und
# zählt daher nicht als wedged; GPU 0 (Stagger 0) claimt bei gesundem Worker in
# ~8 s -> 0 GPU busy trotz Backlog ist schon nach ~1 min echt festgefahren.
# 90 s deckt Startup + Stagger + Probe-Staleness ab.
WORKER_WEDGE_GRACE=90
# Nach so vielen erfolglosen Auto-Neustarts OHNE echten Fortschritt (kein Clip
# wird fertig) gibt der Supervisor auf (nur noch TUI-Alarm -> Mensch muss ran);
# verhindert ein Restart-Karussell bei wiederkehrendem OOM. Wird ein Clip fertig,
# gibt es frisches Budget.
WORKER_WEDGE_MAX_RESTARTS=3

# --- Work-Stealing (leere Nodes ziehen Arbeit an sich) -----------------------
# Kommt ein Node SPÄT dazu, während ein früher Node bereits alle Clips hochgeladen
# hat (weniger Clips als sein Puffer), bekäme der neue Node sonst nie Arbeit —
# einmal hochgeladene Clips kleben an ihrer Node. Ist WORK_STEAL=1, klaut ein Node
# mit freien GPUs wartende (noch NICHT gestartete) uploaded-Clips von einem Node
# mit Überschuss: atomarer Claim-Lock verhindert Doppelverarbeitung, die Datei
# wird auf der Quelle gelöscht und auf dem Ziel neu hochgeladen. 0 = aus (Clips
# bleiben, wo sie zuerst landen).
WORK_STEAL=1

# --- Modell-Bereitstellung ---------------------------------------------------
# Modelle kommen ZUERST per Node-Selbst-Download von HuggingFace (schneller Pfad,
# curl --ipv4 umgeht die IPv6-only-HF-Falle); scheitert das, FALLBACK auf den
# rsync-Push vom Orchestrator-Home-Cache. Dieser Wert = max. Sekunden je Modell-
# datei für den Node-Download, bevor auf rsync zurückgefallen wird.
MODEL_NODE_DL_TIMEOUT=600

# --- Kostenmodell (Video-/Kostenübersicht im Menü) ---------------------------
# HINWEIS: Die Kosten-Seite der TUI ([k]) bzw. `vhsorch costs` rechnet UNABHÄNGIG
# hiervon mit der ECHTEN Rate (Node-Rechnung ÷ per ffprobe gemessene Frames) und
# braucht keine Konfiguration. Das Modell hier speist nur die Video-Liste.
#
# Kosten pro Video (Schätzung) = belegte_Minuten × GPU-Faktor × x
#
# x = Grund-Rate in $ je faktor-gewichteter Minute. Grob an deinen $/h pro GPU
# ausrichten (z. B. 0.40 $/h/GPU ≈ 0.0067). Default konservativ.
COST_RATE_X=0.01
# Relative Rechenleistungs-Faktoren pro GPU-Typ (Substring-Match gegen den
# GPU-Namen). Komma-separiert, "NAME=FAKTOR". Leer = eingebaute Defaults
# (RTX 4090=1.0, RTX 5090=1.7).
GPU_COST_FACTORS=RTX 4090=1.0,RTX 5090=1.7
# Faktor für unbekannte GPU-Typen.
GPU_FACTOR_DEFAULT=1.0
