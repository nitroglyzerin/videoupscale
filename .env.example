# ============================================================================
#  VHS-Upscale-Orchestrator — Konfiguration
#  Kopiere diese Datei nach `.env` und trage deine Werte ein.
#  .env ist in .gitignore — Secrets landen NIE im Repo.
# ============================================================================

# --- Vast.ai -----------------------------------------------------------------
# Dein Vast API Key (console.vast.ai -> Account -> API Key).
# WIRD NUR ALS ENV-VAR / DOCKER-SECRET GELESEN, niemals im Code hardcodieren.
VAST_API_KEY=

# Docker-Image für die Vast-Node. Die RTX 5090 (Blackwell, sm_120) braucht ein
# torch mit cu128/sm_120-Kernel — sonst scheitert schon torch.randn(device=cuda)
# und bootstrap.sh müsste torch mehrere GB groß neu installieren (langsam!).
# vastai/pytorch:@vastai-automatic-tag wählt den zur GPU passenden CUDA-Build
# (für die 5090 = cu128) -> torch funktioniert sofort, der cu128-Reinstall in
# bootstrap.sh entfällt. Die Probe+Reinstall-Logik bleibt als Sicherheitsnetz.
# (Fallback bei Buchungsproblemen: pytorch/pytorch:2.8.0-cuda12.8-cudnn9-devel)
VAST_IMAGE=vastai/pytorch:@vastai-automatic-tag

# Disk in GB, die bei der Buchung angefragt wird (>= 300 laut Anforderung).
VAST_DISK_GB=320

# --- SSH (ausgehend Home -> Vast) --------------------------------------------
# Privater SSH-Key, mit dem der Orchestrator die Node erreicht.
# Der ZUGEHÖRIGE ÖFFENTLICHE Key muss in deinem Vast-Account hinterlegt sein
# (console.vast.ai -> Account -> SSH Keys), damit die Instanzen ihn akzeptieren.
SSH_KEY_PATH=/secrets/id_ed25519

# Optionaler zusätzlicher Public-Key-String, den bootstrap.sh in die
# authorized_keys der Node schreibt (Fallback, meist nicht nötig).
SSH_PUBKEY=

# --- Datenpfade (im Container) -----------------------------------------------
# Diese Pfade sind CONTAINER-INTERN. Das Mapping auf die WD Red passiert in
# docker-compose.yml (siehe dortige Kommentare / Sicherheitshinweise).
RAW_DIR=/data/raw
DONE_DIR=/data/done
STATE_DIR=/state

# --- Node-Bootstrap ----------------------------------------------------------
# Roh-URL zu process.sh in DEINEM public Repo (curl-Bootstrapping).
# Nach dem ersten `git push` ggf. Branch/Handle anpassen.
REPO_RAW_URL=https://raw.githubusercontent.com/nitroglyzerin/videoupscale/main

# --- Scheduler ---------------------------------------------------------------
# Wie oft der run-Loop pollt (Sekunden).
POLL_INTERVAL=30
# Datei gilt als "vollständig hochgeladen", wenn ihre Größe über so viele
# aufeinanderfolgende Checks stabil bleibt.
STABLE_CHECKS=2
# Auto-Destroy: Node zerstören, sobald ihre Queue leer UND alle Ergebnisse
# eingesammelt sind. 1 = an (Kostenschutz, empfohlen), 0 = aus.
AUTO_DESTROY=1
# Flow-Control für den Upload: pro Node werden nur so viele Clips gleichzeitig
# "in Arbeit" gehalten wie die Node GPUs hat, multipliziert mit diesem Faktor.
# Nachschub kommt erst, wenn die Node Rückstand abbaut -> minimaler Node-
# Speicher, Rohvideos bleiben zuhause, Upload+Verarbeitung überlappen.
#   1 = exakt GPU-Menge (straffster Puffer), 2 = etwas Reserve (empfohlen).
INFLIGHT_PER_GPU=2

# --- Kostenmodell (Video-/Kostenübersicht im Menü) ---------------------------
# Kosten pro Video (Schätzung) = belegte_Minuten × GPU-Faktor × x
#
# x = Grund-Rate in $ je faktor-gewichteter Minute. Grob an deinen $/h pro GPU
# ausrichten (z. B. 0.40 $/h/GPU ≈ 0.0067). Default konservativ.
COST_RATE_X=0.01
# Relative Rechenleistungs-Faktoren pro GPU-Typ (Substring-Match gegen den
# GPU-Namen). Komma-separiert, "NAME=FAKTOR". Leer = eingebaute Defaults
# (RTX 4090=1.0, RTX 5090=1.7).
GPU_COST_FACTORS=RTX 4090=1.0,RTX 5090=1.7
# Faktor für unbekannte GPU-Typen.
GPU_FACTOR_DEFAULT=1.0
